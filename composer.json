{
    "name": "irabbi360/laravel-goal-captcha",
    "description": "A football goal slider CAPTCHA system for Laravel — anti-bot, mobile-friendly, themeable.",
    "keywords": [
        "laravel",
        "captcha",
        "goal-captcha",
        "football-captcha",
        "slider-captcha",
        "anti-bot",
        "human-verification"
    ],
    "homepage": "https://github.com/irabbi360/laravel-goal-captcha",
    "license": "MIT",
    "authors": [
        {
            "name": "Fazle Rabbi",
            "email": "fazle08rabbi@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^11.0||^12.0",
        "illuminate/support": "^11.0||^12.0",
        "illuminate/http": "^11.0||^12.0",
        "illuminate/cache": "^11.0||^12.0",
        "illuminate/routing": "^11.0||^12.0"
    },
    "require-dev": {
        "laravel/pint": "^1.14",
        "nunomaduro/collision": "^8.1",
        "larastan/larastan": "^2.9",
        "orchestra/testbench": "^9.0",
        "pestphp/pest": "^2.0",
        "pestphp/pest-plugin-arch": "^2.0",
        "pestphp/pest-plugin-laravel": "^2.0",
        "phpstan/extension-installer": "^1.3",
        "phpstan/phpstan-deprecation-rules": "^1.1",
        "phpstan/phpstan-phpunit": "^1.3"
    },
    "autoload": {
        "psr-4": {
            "Irabbi360\\LaravelGoalCaptcha\\": "src/",
            "Irabbi360\\LaravelGoalCaptcha\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Irabbi360\\LaravelGoalCaptcha\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Irabbi360\\LaravelGoalCaptcha\\GoalCaptchaServiceProvider"
            ],
            "aliases": {
                "GoalCaptcha": "Irabbi360\\LaravelGoalCaptcha\\Facades\\GoalCaptcha"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}